# Public URL of the app (e.g. http://localhost:3000)
APP_URL=

# Internal URL the frontend container uses to reach the backend over the Docker network
# In docker-compose this is http://backend:<port>; in dev it is http://localhost:<backend-port>
BACKEND_INTERNAL_URL=

# 32-byte random secret used for AES-GCM encryption of OAuth tokens
ENCRYPTION_SECRET=

# EVE SSO OAuth2 client credentials (register at https://developers.eveonline.com)
ESI_CLIENT_ID=
ESI_CLIENT_SECRET=

# PostgreSQL credentials (used by docker-compose to initialise the database)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
