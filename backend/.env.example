# Copy to `.env` and fill in the blanks.  Used by `cargo run` (via dotenvy).
#
# Tests do NOT read this file; they get DATABASE_URL from `.cargo/config.toml`
# and build their own in-memory Config.  See CONTRIBUTING.md.

# Public URL of the app (e.g. http://localhost:8080)
APP_URL=http://localhost:8080

# 32-byte random secret used for AES-GCM encryption of OAuth tokens and JWT
# signing.  Generate with: `openssl rand -hex 32`
ENCRYPTION_SECRET=

# EVE SSO OAuth2 client credentials.  Register an application at
# https://developers.eveonline.com to obtain these.
ESI_CLIENT_ID=
ESI_CLIENT_SECRET=

# PostgreSQL connection string.  Default matches the role/database described
# in CONTRIBUTING.md.
DATABASE_URL=postgres://erbridge:Passw0rd@localhost/erbridge?sslmode=disable
