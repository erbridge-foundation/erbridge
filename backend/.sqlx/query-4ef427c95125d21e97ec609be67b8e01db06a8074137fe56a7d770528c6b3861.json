  "query": "UPDATE session\n         SET last_seen_at = now(),\n             expires_at = now() + interval '7 days'\n         WHERE session_id = $1 AND expires_at > now()\n         RETURNING session_id, account_id,\n                   created_at, last_seen_at, expires_at",
